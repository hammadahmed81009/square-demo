{
  "name": "per-diem",
  "version": "0.1.0",
  "private": true,
  "description": "A secure, multi-location Square menu browser for the Per Diem full-stack challenge.",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": "22.x",
    "pnpm": "10.14.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.12",
      "sharp": "0.35.0"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "secrets:scan": "secretlint \"**/*\" \".env.example\"",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:integration && pnpm build",
    "ci": "pnpm verify && pnpm test:e2e && pnpm audit:prod && pnpm secrets:scan"
  },
  "dependencies": {
    "decimal.js": "10.6.0",
    "idb-keyval": "6.2.2",
    "luxon": "3.7.2",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "server-only": "0.0.1",
    "square": "45.0.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "11.3.1",
    "@tailwindcss/postcss": "4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/luxon": "3.7.1",
    "@types/node": "^22.20.1",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9",
    "eslint-config-next": "16.2.11",
    "fake-indexeddb": "6.2.2",
    "jsdom": "28.1.0",
    "msw": "2.12.7",
    "secretlint": "11.3.1",
    "tailwindcss": "4",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.17"
  }
}
